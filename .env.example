# Copy to .env.local and fill in real values. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CLI-only (migrations): personal access token + database password
SUPABASE_ACCESS_TOKEN=your-sbp-token
SUPABASE_DB_PASSWORD=your-database-password

# Google OAuth is implemented but hidden until the provider is configured in
# Supabase (Auth → Providers → Google). Set to "true" to show the button.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
