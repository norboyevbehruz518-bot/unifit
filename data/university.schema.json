{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unifit.app/schemas/university.schema.json",
  "title": "University seed record",
  "description": "One row for the public.universities table (supabase/migrations/20260612000000_initial_schema.sql). Field shapes and ranges mirror that table's columns and CHECK constraints. null always means 'not published' (DOMAIN.md §3.2) — never an invented value.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "state",
    "city",
    "setting",
    "undergrad_enrollment",
    "type",
    "major_categories",
    "acceptance_rate_overall",
    "acceptance_rate_intl",
    "sat25",
    "sat50",
    "sat75",
    "act25",
    "act50",
    "act75",
    "gpa_distribution",
    "test_policy",
    "ielts_min",
    "toefl_min",
    "cost_of_attendance_usd",
    "intl_aid_policy",
    "avg_intl_aid_usd",
    "pct_intl_receiving_aid",
    "cds_url",
    "admission_source_url",
    "admission_source_year",
    "cost_source_url",
    "cost_source_year",
    "aid_source_url",
    "aid_source_year",
    "field_confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Stable slug, e.g. 'purdue-west-lafayette'."
    },
    "name": { "type": "string", "minLength": 1 },
    "state": { "type": "string", "minLength": 2, "maxLength": 2 },
    "city": { "type": "string", "minLength": 1 },
    "setting": { "type": "string", "enum": ["urban", "suburban", "rural"] },
    "undergrad_enrollment": { "type": "integer", "exclusiveMinimum": 0 },
    "type": { "type": "string", "enum": ["public", "private"] },
    "major_categories": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Must be drawn from data/major-categories.json (checked in seed.test.ts, not by this schema)."
    },

    "acceptance_rate_overall": { "type": "number", "minimum": 0, "maximum": 100 },
    "acceptance_rate_intl": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },

    "sat25": { "type": ["integer", "null"], "minimum": 400, "maximum": 1600 },
    "sat50": { "type": ["integer", "null"], "minimum": 400, "maximum": 1600 },
    "sat75": { "type": ["integer", "null"], "minimum": 400, "maximum": 1600 },
    "act25": { "type": ["integer", "null"], "minimum": 1, "maximum": 36 },
    "act50": { "type": ["integer", "null"], "minimum": 1, "maximum": 36 },
    "act75": { "type": ["integer", "null"], "minimum": 1, "maximum": 36 },
    "gpa_distribution": {
      "type": ["object", "null"],
      "description": "CDS C11 banded percentages when published (DOMAIN.md §1.2); not consumed by the fit engine in v1."
    },
    "test_policy": { "type": "string", "enum": ["required", "optional", "blind"] },
    "ielts_min": { "type": ["number", "null"], "minimum": 0, "maximum": 9 },
    "toefl_min": { "type": ["number", "null"], "minimum": 0, "maximum": 120 },

    "cost_of_attendance_usd": { "type": "integer", "exclusiveMinimum": 0 },
    "intl_aid_policy": {
      "type": "string",
      "enum": ["need-blind-full-need", "need-aware", "merit-only", "none"]
    },
    "avg_intl_aid_usd": { "type": ["integer", "null"], "minimum": 0 },
    "pct_intl_receiving_aid": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },

    "cds_url": { "type": "string", "format": "uri" },
    "admission_source_url": { "type": "string", "format": "uri" },
    "admission_source_year": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "cost_source_url": { "type": "string", "format": "uri" },
    "cost_source_year": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "aid_source_url": { "type": "string", "format": "uri" },
    "aid_source_year": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },

    "field_confidence": {
      "type": "object",
      "description": "Per-field provenance (DOMAIN.md §3.2). Keys are field names from this schema; values are confidence levels.",
      "additionalProperties": {
        "type": "string",
        "enum": ["verified-intl", "verified-overall", "estimated", "missing"]
      }
    }
  }
}
